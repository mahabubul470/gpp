[0.006, "o", "\r\n\u001b[1;36m# gpp — version control that remembers, and knows when it's wrong\u001b[0m\r\n"]
[1.001, "o", "\r\n\u001b[1m$ gpp init --graphex\u001b[0m\r\n"]
[1.004, "o", "Initialized empty gpp repository in /tmp/tmp.g6D61uEhr9/.gpp\r\n  Graphex knowledge graph: enabled\r\n"]
[0.003, "o", "\r\n\u001b[1m$ gpp timeline\u001b[0m\r\n"]
[1.006, "o", "#1     0s ago    human:unknown@localhost      1 file changed via cli\r\n"]
[0.000, "o", "\r\n\u001b[1m$ gpp promote -m seed auth --intent feature\u001b[0m\r\n"]
[1.007, "o", "Promoted 1 timeline entry → cs:bfsg5l7c on main\r\n"]
[0.001, "o", "\r\n\u001b[1m$ gpp diff   # tree-sitter: a rename is one op\u001b[0m\r\n"]
[1.013, "o", "src/auth.rs\r\n  » fn issue_token → create_token  (renamed)\r\n"]
[0.007, "o", "\r\n\u001b[1m$ gpp belief add --claim token expiry is 24h --evidence src/auth.rs:5-5\u001b[0m\r\n"]
[1.006, "o", "Recorded belief 7aurbnah anchored at cs:7vglzgpj\r\n  \"token expiry is 24h\"\r\n"]
[0.000, "o", "\r\n\u001b[1;36m# ...weeks pass; someone changes the expiry...\u001b[0m\r\n"]
[1.010, "o", "\r\n\u001b[1m$ gpp belief stale\u001b[0m\r\n"]
[1.006, "o", "invalidated      7aurbnah  \"token expiry is 24h\"\r\n    2026-07-11  cs:7yw7cvgm  invalidated  — evidence src/auth.rs:5-5 changed\r\n"]
[1.001, "o", "\r\n\u001b[1m$ gpp belief bisect token expiry is 24h\u001b[0m\r\n"]
[1.007, "o", "belief 7aurbnah  \"token expiry is 24h\"\r\n  anchored at cs:7vglzgpj · status: invalidated\r\n\r\nINVALIDATED  cs:7yw7cvgm  2026-07-11\r\n  \"raise token expiry to 7 days\"\r\n  cause: evidence src/auth.rs:5-5 changed\r\n\r\n       3 | }\r\n       4 | \r\n -     5 | pub const EXPIRY_HOURS: u64 = 24;\r\n +     5 | pub const EXPIRY_HOURS: u64 = 168;\r\n"]
